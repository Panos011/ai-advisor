FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY requirements_ui.txt /app/requirements_ui.txt
RUN pip install --upgrade pip && pip install -r requirements_ui.txt

COPY . /app

EXPOSE 10000

CMD ["sh", "-c", "streamlit run app.py --server.port ${PORT:-10000} --server.address 0.0.0.0 --server.enableCORS false --server.enableXsrfProtection false"]